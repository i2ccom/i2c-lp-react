{
  "name": "i2c-landingpage",
  "version": "1.0.0",
  "description": "i2c landing page. React 18 + Vite + TypeScript + Bulma",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "release": "semantic-release",
    "cf:preview": "wrangler pages dev dist",
    "cf:deploy": "pnpm build && wrangler pages deploy dist --project-name i2cw-com",
    "surge": "surge ./dist i2cweb.surge.sh",
    "surge-prod": "surge ./dist i2c.vn",
    "surge-all": "pnpm build && pnpm surge && pnpm surge-prod"
  },
  "dependencies": {
    "bulma": "^1.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "react-slick": "^0.31.0",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "semantic-release": "^24.2.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^3.114.12"
  }
}
